{
  "name": "debug-comments",
  "displayName": "debug-comments",
  "description": "A VS code extension to simplify debugging.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "debug-comments.toggle",
        "title": "Toggle Debug Comment"
      },
      {
        "command": "debug-comments.toggleAllUnnamed",
        "title": "Toggle All Unnamed Debug Comments"
      },
      {
        "command": "debug-comments.toggleByName",
        "title": "Toggle Debug Comments By Name"
      }
    ],
    "keybindings": [
      {
        "command": "debug-comments.toggle",
        "key": "ctrl+shift+j",
        "when": "editorTextFocus"
      },
      {
        "command": "debug-comments.toggleAllUnnamed",
        "key": "ctrl+alt+j a",
        "when": "editorTextFocus"
      },
      {
        "command": "debug-comments.toggleByName",
        "key": "ctrl+alt+j n",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.82.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
